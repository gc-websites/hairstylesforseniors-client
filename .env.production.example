# Copy this file to `.env.production` and fill in real values before building.
# These are PUBLIC (they end up in the HTML), so they are safe to commit if you
# prefer — they are not secrets.

# Google Search Console verification token.
# In Search Console choose "HTML tag" verification and copy ONLY the value of the
# content attribute (the long token), not the whole <meta> tag.
# vite.config.ts injects it as <meta name="google-site-verification" ...>.
VITE_GSC_TOKEN=

# Forum write proxy (thread/reply/like/view). Leave unset to use the default.
# Consider pointing this at your own neutral API host instead of a third party.
# VITE_FORUM_PROXY=https://api.yourdomain.com
